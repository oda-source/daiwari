					!$("#dm").is(":checked") && !$("#orikomi").is(":checked") &&
					!$("#sofu").is(":checked") && !$("#other").is(":checked")) {
					
				alert('メディア種類を選択してください。');
				return false;		
			}
			// 登陆的检查消息
			var errorMsg = "";
			var checkSubmit = true;
			
			// 备考 长度限制 300个字符
			var bikou = $.trim($("#txt_bikou").val());
			if (bikou.length > 300) {
			
				checkSubmit = false;
				$("#err_bikou").html("備考に300文字以内を入力してください");
			} else {
			
				$("#err_bikou").html("&nbsp;");
			}
			
			
			if (!$("#mediano_name").isNotNulls("#toroku_err_msg", "媒体名を入力してください。", true)) {
				
				checkSubmit = false;
			}
			if (!$("#mediano").isNotNulls("#toroku_err_msg", "媒体コードを入力してください。", true)) {
				
				checkSubmit = false;
			} else if (!$("#mediano").isKosuNo("#toroku_err_msg", "半角英数字で入力してください。", true, -1, 24)) {
		
				checkSubmit = false;
			}
			if (!$("#cmb_honbucd").isNotNulls("#toroku_err_msg", "営業本部を選択してください。", checkSubmit)) {

				checkSubmit = false;
			}
			
			if (!$('#publish_panel').checkPublishData()) {
						
				checkSubmit = false;
			}
			var kosuContinuous = $("#kosuContinuous").getKosuContinuousData();
			var isCsv = true;
			if (kosuContinuous && kosuContinuous.length > 0 || $.kosuContinuousDataList.length > 1) {
			
				$("#errDiv_fileText").remove();
				
				// 设置正确的边框颜色
				$("#fileText").css({border: "solid 1px #7e9ebb"});
				
				if (!$("#kosuContinuous").checkKosuContinuousData()) {
				
					checkSubmit = false;
				}
				
				isCsv = false;
			} else if (!$("#fileText").isNotNulls("#file_err_msg", "連続登録CSVファイル、またはコース情報を手入力してください。", checkSubmit)) {
			
				checkSubmit = false;
				
				if (!$("#kosuContinuous").checkKosuContinuousData()) {
				
					checkSubmit = false;
				}
			}
			
			/*var umucheckbox = false;
			if ($("#umucheckbox").is(":checked")) {
				
				umucheckbox = true;
			}*/
			if (checkSubmit) {
				
				showmessage("登録中...");
				var keisaiHasou = $("#publish_panel").getPublishData();
				var keisaiHasou_s1 = "";
				var keisaiHasou_s2 = "";
				for( var i=1; i<keisaiHasou.length; i++){
				    if( keisaiHasou_s1 == "" ){
				    	keisaiHasou_s1 = keisaiHasou[i][0];
				    }
				    else{
				    	keisaiHasou_s1 += "," + keisaiHasou[i][0];
				    }
				    if( keisaiHasou_s2 == "" ){
				    	keisaiHasou_s2 = keisaiHasou[i][1];
				    }
				    else{
				    	keisaiHasou_s2 += "," + keisaiHasou[i][1];
				    }
				}
				var url = "panfuretoAjaxFile";
				url += "?mediano=" + $("#mediano").val();
				url += "&medianame=" + encodeURIComponent($.trim($("#mediano_name").val()));
				url += "&honbucd=" + $("#cmb_honbucd").val();
				url += "&bucd=" + $("#cmb_bucd").val();
				url += "&kacd=" + $("#cmb_kacd").val();
				url += "&bikou=" + $("#txt_bikou").val();
				url += "&denpyouno=" + $("#denpyouno").val();
				url += "&hasoudate=" + $("#date_panfureto").val();
				url += "&panfuretotype=" + $("input[name=pan]:checked").val();
				url += "&files=" + $.trim($("#target_box").attr("images"));
				url += "&keisaiHasou1=" + keisaiHasou_s1;
				url += "&keisaiHasou2=" + keisaiHasou_s2;
				url += "&panfuretoPublish=" + $("#publish_panel").getPublishData().length;

				url += "&isCsv=" + isCsv;
				//url += "&umucheckbox=" + umucheckbox;
				
				if (isCsv) {
					if ($.browser().sys != "ie" || $.browser().sys == "ie" && parseInt($.browser().version) > 9) {
	
						url += "&isIE=false";
						
						//获取文件列表
						var fileList = $("#fileObj")[0].files;
						
						//检测是否是有文件
						if(fileList.length == 0) {
						
							return;
						}
						
						var xhr = new XMLHttpRequest();
						xhr.open("post", url, true);
						xhr.setRequestHeader("X-Requested-With", "XMLHttpRequest");
						xhr.upload.addEventListener("progress", function(e) {
							if(e.lengthComputable){
								// 100%
								var loaded = Math.ceil((e.loaded / e.total) * 100);
							}
						}, false);
						xhr.addEventListener("load", function(e) {
	
							var request = eval("(" + e.target.response + ")");
							requestShowFun(request);
						}, false);
						
						var fd = new FormData();
						fd.append('fileObj', fileList[0]);
						xhr.send(fd);
						resets();
					} else {
	
						url += "&isIE=true";
						$("#panfureto2_form").attr("action", url);
						$("#panfureto2_form").submit();
						resets();
					}
				} else {
					
					$.ajax({
						url: url,
						type: "post",
						data: {
							"kosuContinuous": $("#kosuContinuous").getKosuContinuousData()
						}
					}).done(function(data) {
						resets();
						var request = eval("(" + data + ")");
						requestShowFun(request);
					});
				}
			}
		});
	});
	
