	$("#logout").click(function () {
		
		// 登陆确认对话框
		var isLogout = confirm("ログアウトします。よろしいですか？");
		
		// 登出调用。
		if (isLogout) {

			$.ajax({
			
				url: "/index.php/login/logout",
				type: "get",
				data: {
					'isLogout': isLogout
				}
			}).done(function(data) {

				var request = eval("(" + data + ")");
				var isSuccess = eval(request.success);

				if (isSuccess) {

					// 画面跳转至主页,返回到登陆页面
					document.location.href = "/index.php/login/index";
				}
			});
		}
	});
});
