	<script type="text/javascript">
		// 防抖函数
		var denpyounoSearchTimer = null;
		var denpyounoSearchDelay = 500; // 500ms 延迟

		// 根据伝票番号搜索スケジュール信息
		function searchScheduleByDenpyouno() {
			var denpyouno = $.trim($('#denpyouno').val());
			var $display = $('#schedule_info_display');

			if (denpyouno === '') {
				$display.html('');
				return;
			}

			$display.html('<span style="color: #999;">検索中...</span>');

			$.ajax({
				url: "/index.php/panfureto/searchScheduleByDenpyou",
				type: "post",
				data: {
					'denpyouno': denpyouno
				}
			}).done(function(data) {
				var result = eval("(" + data + ")");
				if (result.success && result.data) {
					$display.html('<span style="color: #0066cc;">[' + result.data.ScheduleNo + '] ' + result.data.ScheduleTitle + '</span>');
				} else {
					$display.html('<span style="color: #cc0000;">' + result.message + '</span>');
				}
			}).fail(function() {
				$display.html('<span style="color: #cc0000;">検索エラーが発生しました。</span>');
			});
		}

		// 伝票番号入力時の防抖処理
		$(document).ready(function() {
			$('#denpyouno').on('input', function() {
				// 前のタイマーをクリア
				if (denpyounoSearchTimer) {
					clearTimeout(denpyounoSearchTimer);
				}
				// 新しいタイマーをセット
				denpyounoSearchTimer = setTimeout(function() {
					searchScheduleByDenpyouno();
				}, denpyounoSearchDelay);
			});
		});

		function slectFile() {

			if($.trim($('#denpyouno').val()) == '')
			{
				return;
			}
			$.ajax({
				url: "/index.php/panfureto/readFile",
				type: "post",
				data: {
					'denpyouno': $.trim($('#denpyouno').val())
				}
			}).done(function(data) {
			
				var text = eval("(" + data + ")");
				
				if($.trim(text) == '')
				{
					return;
				}
				var kosuContinuous = $("#kosuContinuous select");
				var kosuContinuousCount = kosuContinuous.length;
				for (var kosuConIndex = 0; kosuConIndex < kosuContinuousCount; kosuConIndex++) {
				
					if ($(kosuContinuous[kosuConIndex]).attr("id").indexOf("syupatutiname") > 0 &&
							$(kosuContinuous[kosuConIndex]).val() == "") {
					
						$(kosuContinuous[kosuConIndex]).val(text[0]['origincd']);
						$(kosuContinuous[kosuConIndex]).change();
					}
				}
				if ($('#kosuContinuous').getKosuContinuousData().length <= 0) {
				
					$('#fileText').css({'background-color': '#fff'});
				} else {
				
					$('#fileText').css({'background-color': '#eee'});
					$('#errDiv_fileText').remove();
					$('#fileText').css({'border': 'solid 1px #7e9ebb'});
				}
				
				$("#cmb_honbucd").val(text[0]['honbucd']);
				$("#cmb_honbucd").change();
					
				$("#cmb_bucd").val(text[0]['bucd']);
				$("#cmb_bucd").change();
					
				$("#cmb_kacd").val(text[0]['kacd']);
					
				$("#txt_bikou").val(text[0]['biko']);
				
				if(text[0]['hasounumber']=="0"){
					
					text[0]['hasounumber']="";
				}
				if(text[0]['hasoudate']=="0000-00-00"){
					
					text[0]['hasoudate']="";
				}
				if(text[0]['hasoudate'] !="" || text[0]['hasounumber'] !=""){
					
					var isflg = true;
					var buarray=$("#publish_panel").getPublishData();
					for (var i=0; i<buarray.length; i++){
						
						var date=text[0]['hasoudate'].replace("-","").replace("-","").replace("/","").replace("/","");
						var newdate = "";
						if (buarray && buarray[i]){
							
							newdate=buarray[i][0].replace("-","").replace("-","").replace("/","").replace("/","");
						}
						if (buarray && buarray[i] && date == newdate && text[0]['hasounumber'] == buarray[i][1]){
							
							isflg = false;
						}
					}
					if (isflg) {
					
						if ($("#publish_panel").getPublishData().length <= 0) {
						
							$("#publish_panel").publish({"title": "発送日", "add": [text[0]['hasoudate'], text[0]['hasounumber']]});
						} else {
						
							$("#publish_panel").publish({"add": [text[0]['hasoudate'], text[0]['hasounumber']]});
						}
					}
				}
			});
		}

	function requestShowFun (request) {

		var isSuccess = eval(request.success);
		var message = request.message;
		if (isSuccess) {

			$("#torokuJyoukyou").html('<tr>' +
					'<td width="30" class="title">No.</td>' +
					'<td width="100" class="title">コース番号</td>' +
					'<td class="title">コース名</td>' +
					'<td width="60" class="title">登録結果</td>' +
					'<td width="300" class="title">エラーメッセージ</td>' +
				'</tr>');
			for (var index in request.successMsgList) {

				var torokuJyoukyouRow = request.successMsgList[index];
				$("#torokuJyoukyou").append('<tr>' +
						'<td width="30" class="title">' + (parseInt(index) + 1) + '</td>' +
						'<td width="100" class="title">' + torokuJyoukyouRow['kosuno'] + '</td>' +
						'<td class="title">' + torokuJyoukyouRow['kosuname'] + '</td>' +
						'<td width="60" class="title">' + torokuJyoukyouRow['success'] + '</td>' +
						'<td width="300" class="title">' + torokuJyoukyouRow['message'] + '</td>' +
					'</tr>');
			}
			$(".pdf2imgDelAll").click();
			$("#csv_data_panel").show();
		
		} else {
			closewin();
			alert(message);
			$("#csv_data_panel").hide();
		}
		closewin();
		$.autoHeight();
	}
	
